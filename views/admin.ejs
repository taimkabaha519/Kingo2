            function banIp() {
                const ipInput = document.getElementById('ban-ip-input');
                if (!ipInput) {
                    console.error('ban-ip-input element not found');
                    return;
                }

                const ip = ipInput.value.trim();
                if (!ip) {
                    showToast('يرجى إدخال عنوان IP', 'error');
                    return;
                }

                // Validate IP format
                const ipRegex = /^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;
                if (!ipRegex.test(ip)) {
                    showToast('يرجى إدخال عنوان IP صحيح', 'error');
                    return;
                }

                console.log('Banning IP:', ip);
                showSpinner();

                // Simulate API call
                setTimeout(() => {
                    hideSpinner();
                    showToast(`تم حظر عنوان IP: ${ip}`, 'success');
                    ipInput.value = '';
                    refreshBannedIps();
                }, 1000);
            }

            function unbanIpDirect(ip) {
                if (!ip) {
                    console.error('No IP provided to unban');
                    return;
                }

                console.log('Unbanning IP:', ip);
                showSpinner();

                // Simulate API call
                setTimeout(() => {
                    hideSpinner();
                    showToast(`تم إلغاء حظر عنوان IP: ${ip}`, 'success');
                    refreshBannedIps();
                }, 800);
            }

