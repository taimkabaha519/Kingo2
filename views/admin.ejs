        function savePackage(serviceType, index) {
            const item = document.querySelector(`#${serviceType}-packages-container .package-item[data-index="${index}"]`);
            if (!item) return;

            const packageData = {
                name: item.querySelector('.package-name').value,
                price: parseFloat(item.querySelector('.package-price').value),
                ram: parseInt(item.querySelector('.package-ram').value),
                cpu: parseInt(item.querySelector('.package-cpu').value),
                storage: parseInt(item.querySelector('.package-storage').value),
                duration: parseInt(item.querySelector('.package-duration').value)
            };

            fetch('/api/admin/update-package', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ serviceType, index, package: packageData })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showToast('تم حفظ الباقة بنجاح', 'success');
                        loadPricingConfig();
                    } else {
                        showToast('فشل الحفظ: ' + (data.message || ''), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    showToast('خطأ في الاتصال', 'error');
                });
        }

