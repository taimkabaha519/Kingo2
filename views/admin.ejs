        }

        // Load logs preview data
        async function loadLogsPreview() {
            try {
                const response = await fetch('/api/admin/logs/stats');
                const stats = await response.json();

                document.getElementById('total-logs-preview').textContent = stats.total || 0;
                document.getElementById('errors-preview').textContent = stats.errorsCount || 0;

                // Load recent logs
                const logsResponse = await fetch('/api/admin/logs?limit=5');
                const logsData = await logsResponse.json();

                if (logsData.success && logsData.logs.length > 0) {
                    const recentLogsHtml = logsData.logs.map(log => `
                <div class="recent-log-item">
                    <div class="log-time">${new Date(log.timestamp).toLocaleString('ar-SA')}</div>
                    <div class="log-description">${log.description}</div>
                    <div class="log-user">${log.username || 'مجهول'}</div>
                </div>
            `).join('');

                    document.getElementById('recent-logs-preview').innerHTML = recentLogsHtml;
                } else {
                    document.getElementById('recent-logs-preview').innerHTML = '<div class="text-muted">لا توجد أنشطة حديثة</div>';
                }
            } catch (error) {
                console.error('Error loading logs preview:', error);
            }
        }

