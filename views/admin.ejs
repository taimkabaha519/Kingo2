                const userId = userIdInput.value.trim();
                const username = usernameInput ? usernameInput.value.trim() : '';

                if (!userId) {
                    showToast('يرجى إدخال معرف المستخدم', 'error');
                    return;
                }

                // Validate user ID (should be numeric)
                if (!/^\d+$/.test(userId)) {
                    showToast('معرف المستخدم يجب أن يكون أرقام فقط', 'error');
                    return;
                }

                console.log('Banning user:', userId, username);
                showSpinner();

                // Simulate API call
                setTimeout(() => {
                    hideSpinner();
                    const displayName = username || `User_${userId}`;
                    showToast(`تم حظر المستخدم: ${displayName}`, 'success');
                    userIdInput.value = '';
                    if (usernameInput) usernameInput.value = '';
                    refreshBannedUsers();
                }, 1000);
