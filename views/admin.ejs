        function renderGiveaways(giveaways) {
            const container = document.getElementById('giveaways-container');
            if (!container) return;

            const activeGiveaways = giveaways.filter(g => g.status === 'active');

            if (activeGiveaways.length === 0) {
                container.innerHTML = '<p class="text-muted text-center py-4">لا توجد جوائز نشطة</p>';
                return;
            }

            container.innerHTML = activeGiveaways.map(giveaway => {
                const timeLeft = Math.max(0, giveaway.endsAt - Date.now());
                const hoursLeft = Math.floor(timeLeft / (1000 * 60 * 60));
                const minutesLeft = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
                const participantsCount = giveaway.participants ? giveaway.participants.length : 0;
                const maxParticipants = giveaway.maxParticipants || 'غير محدود';
                const progressPercent = giveaway.maxParticipants ? (participantsCount / giveaway.maxParticipants * 100) : 0;

                const prizeTypeNames = {
                    'discord': 'Discord Bot',
                    'web': 'Web Hosting',
                    'minecraft': 'Minecraft Server'
                };

                return `
            <div class="card mb-3 giveaway-item" data-id="${giveaway.id}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="mb-1">${giveaway.title}</h5>
                            <p class="text-muted small mb-2">${giveaway.description || ''}</p>
                            <div class="d-flex gap-3 small text-muted">
                                <span><i class="fas fa-gift me-1"></i> الجائزة: ${prizeTypeNames[giveaway.prizeType] || giveaway.prizeType}</span>
                                <span><i class="fas fa-users me-1"></i> المشاركون: ${participantsCount} / ${maxParticipants}</span>
                                <span><i class="fas fa-clock me-1"></i> المتبقي: ${hoursLeft}س ${minutesLeft}د</span>
                            </div>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-primary" onclick="editGiveaway('${giveaway.id}')">تعديل</button>
                            <button class="btn btn-sm btn-danger" onclick="endGiveaway('${giveaway.id}')">إنهاء</button>
                            <button class="btn btn-sm btn-outline" onclick="deleteGiveaway('${giveaway.id}')">حذف</button>
                        </div>
                    </div>
                    ${giveaway.maxParticipants ? `
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar" role="progressbar" style="width: ${Math.min(progressPercent, 100)}%"></div>
                        </div>
                    ` : ''}
                </div>
            </div>
        `;
            }).join('');
        }

