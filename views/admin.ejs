    <script>
        // Simple and clean JavaScript
        let currentFilter = 'all';

        // Basic functions
        function showHostingsList() {
            const element = document.getElementById('hostings-table-section');
            if (element) {
                element.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        function showUsersList() {
            showToast('قائمة المستخدمين قيد التطوير', 'info');
        }

        function optimizeStorage() {
            const btn = document.getElementById('optimize-storage');
            if (btn) btn.click();
        }

        // Filter function
        function filterHostings(filter) {
            currentFilter = filter;
            const rows = document.querySelectorAll('#hostings-table tbody tr');
            const searchTerm = document.getElementById('hostings-search')?.value.toLowerCase() || '';

            rows.forEach(row => {
                const hostingType = row.getAttribute('data-hosting-type');
                const hostingStatus = row.getAttribute('data-hosting-status');
                let visible = true;

                // Apply filter
                if (filter !== 'all') {
                    if (filter === 'running' && hostingStatus !== 'running') visible = false;
                    else if (filter === 'stopped' && hostingStatus !== 'stopped') visible = false;
                    else if (['discord', 'web', 'mta', 'fivem', 'minecraft'].includes(filter) && hostingType !== filter) visible = false;
                }

                // Apply search
                if (searchTerm && visible) {
                    const textContent = row.textContent.toLowerCase();
                    if (!textContent.includes(searchTerm)) visible = false;
                }

                row.style.display = visible ? '' : 'none';
            });
        }

        // Dropdown function
        function toggleDropdown(dropdownId) {
            const dropdown = document.getElementById(dropdownId);
            if (dropdown) {
                const menu = dropdown.nextElementSibling;
                if (menu && menu.classList.contains('dropdown-menu')) {
                    // Close all other dropdowns
                    document.querySelectorAll('.dropdown-menu').forEach(m => {
                        if (m !== menu) {
                            m.style.display = 'none';
                        }
                    });

                    // Toggle current dropdown
                    if (menu.style.display === 'block') {
                        menu.style.display = 'none';
                    } else {
                        menu.style.display = 'block';
                    }
                }
            }
        }

        // Admin actions
        function adminStart(id) {
            showSpinner();
            fetch(`/api/hosting/${id}/start`, { method: 'POST' })
                .then(r => r.json())
                .then(d => {
                    hideSpinner();
                    if (d.success) {
                        showToast('تم تشغيل الهوست', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('فشل تشغيل الهوست: ' + (d.message || ''), 'error');
                    }
                })
                .catch(() => { hideSpinner(); showToast('خطأ في الاتصال', 'error'); });
        }

        function adminStop(id) {
            showSpinner();
            fetch(`/api/hosting/${id}/stop`, { method: 'POST' })
                .then(r => r.json())
                .then(d => {
                    hideSpinner();
                    if (d.success) {
                        showToast('تم إيقاف الهوست', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('فشل إيقاف الهوست: ' + (d.message || ''), 'error');
                    }
                })
                .catch(() => { hideSpinner(); showToast('خطأ في الاتصال', 'error'); });
        }

        function adminRestart(id) {
            showSpinner();
            fetch(`/api/hosting/${id}/restart`, { method: 'POST' })
                .then(r => r.json())
                .then(d => {
                    hideSpinner();
                    if (d.success) {
                        showToast('تم إعادة تشغيل الهوست', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('فشل إعادة تشغيل الهوست: ' + (d.message || ''), 'error');
                    }
                })
                .catch(() => { hideSpinner(); showToast('خطأ في الاتصال', 'error'); });
        }

        // Specs presets
        const specsPresets = {
            basic: { cpu: 1, ram: 512, storage: 1 },
            standard: { cpu: 2, ram: 1024, storage: 2 },
            premium: { cpu: 4, ram: 2048, storage: 5 },
            custom: { cpu: 1, ram: 512, storage: 1 }
        };

        // Update specs display
        function updateSpecsDisplay() {
            const selectedPreset = document.querySelector('input[name="specPreset"]:checked');
            if (!selectedPreset) return;

            let specs;

            if (selectedPreset.value === 'custom') {
                specs = {
                    cpu: document.getElementById('specsCpu')?.value || 1,
                    ram: document.getElementById('specsRam')?.value || 512,
                    storage: document.getElementById('specsStorage')?.value || 1
                };
            } else {
                specs = specsPresets[selectedPreset.value];
            }

            const displayCpu = document.getElementById('displayCpu');
            const displayRam = document.getElementById('displayRam');
            const displayStorage = document.getElementById('displayStorage');

            if (displayCpu) displayCpu.textContent = specs.cpu;
            if (displayRam) displayRam.textContent = specs.ram + ' MB';
            if (displayStorage) displayStorage.textContent = specs.storage + ' GB';
        }

        // Modal functions
        function openCreateHostingModal() {
            const modal = document.getElementById('createHostingModal');
            if (modal) {
                modal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                // Reset Minecraft options when opening
                toggleMinecraftOptions();
            }
        }

        function closeCreateHostingModal() {
            const modal = document.getElementById('createHostingModal');
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = 'auto';
            }
        }

        function toggleMinecraftOptions() {
            const serviceType = document.getElementById('serviceType').value;
            const minecraftOptions = document.getElementById('minecraftOptions');
            const mainFileInput = document.getElementById('mainFile');

            if (serviceType === 'minecraft') {
                if (minecraftOptions) minecraftOptions.style.display = 'block';
                if (mainFileInput) {
                    mainFileInput.value = 'server.jar';
                }
            } else {
                if (minecraftOptions) minecraftOptions.style.display = 'none';
                if (mainFileInput && (mainFileInput.value === 'server.jar' || !mainFileInput.value)) {
                    mainFileInput.value = 'index.js';
                }
            }
        }

        // Notification Modal functions
        function openCreateNotificationModal() {
            const modal = document.getElementById('createNotificationModal');
            if (modal) {
                modal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
        }

        function closeCreateNotificationModal() {
            const modal = document.getElementById('createNotificationModal');
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = 'auto';
            }
        }

        // Create notification function
        function createNotification() {
            const title = document.getElementById('notificationTitle').value.trim();
            const message = document.getElementById('notificationMessage').value.trim();
            const type = document.getElementById('notificationType').value;
            const priority = document.getElementById('notificationPriority').value;
            const link = document.getElementById('notificationLink').value.trim();
            const expiry = document.getElementById('notificationExpiry').value;
            const targetType = document.querySelector('input[name="targetType"]:checked').value;
            const targetUsers = document.getElementById('targetUsers').value.trim();

            // Validation
            if (!title || !message || !type) {
                showToast('يرجى ملء جميع الحقول المطلوبة', 'error');
                return;
            }

            if (targetType === 'specific' && !targetUsers) {
                showToast('يرجى إدخال أسماء المستخدمين المستهدفين', 'error');
                return;
            }

            // Disable button and show loading
            const btn = document.getElementById('createNotificationBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>جاري الإرسال...';

            // Prepare request data
            const requestData = {
                title,
                message,
                type,
                priority,
                targetType,
                link: link || null,
                expiryDate: expiry || null
            };

            if (targetType === 'specific') {
                requestData.targetUsers = targetUsers.split(',').map(u => u.trim()).filter(u => u);
            }

            console.log('Sending notification request:', requestData);

            // Send request
            fetch('/admin/create-notification', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestData)
            })
                .then(r => r.json())
                .then(d => {
                    if (d.success) {
                        showToast('تم إرسال الإشعار بنجاح! 🎉', 'success');

                        // Reset form
                        document.getElementById('createNotificationForm').reset();
                        document.getElementById('specificUsersSection').style.display = 'none';
                        document.querySelector('input[name="targetType"][value="all"]').checked = true;

                        // Close modal
                        closeCreateNotificationModal();

                        // Reload page after delay
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast('فشل إرسال الإشعار: ' + (d.message || 'خطأ غير معروف'), 'error');
                    }
                })
                .catch(error => {
                    console.error('Network Error:', error);
                    showToast('خطأ في الاتصال بالخادم. تحقق من اتصال الإنترنت.', 'error');
                })
                .finally(() => {
                    // Re-enable button
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });
        }

        // Create hosting function
        function createHosting() {
            const discordId = document.getElementById('discordId').value.trim();
            const hostName = document.getElementById('hostName').value.trim();
            const serviceType = document.getElementById('serviceType').value;
            const port = document.getElementById('port').value;
            const duration = document.getElementById('duration').value;
            const mainFile = document.getElementById('mainFile').value.trim() || 'index.js';
            const selectedPreset = document.querySelector('input[name="specPreset"]:checked');

            if (!selectedPreset) {
                showToast('يرجى اختيار مواصفات الاستضافة', 'error');
                return;
            }

            // Validation
            if (!discordId || !serviceType || !duration) {
                showToast('يرجى ملء جميع الحقول المطلوبة', 'error');
                return;
            }

            // Validate Discord ID format (should be numeric)
            if (!/^\d+$/.test(discordId)) {
                showToast('معرف المستخدم يجب أن يكون رقماً فقط', 'error');
                return;
            }

            // Additional validation for service type
            if (!['discord', 'web', 'mta', 'fivem', 'minecraft'].includes(serviceType)) {
                showToast('نوع الخدمة غير صحيح', 'error');
                return;
            }

            if (port && (port < 1000 || port > 65535)) {
                showToast('المنفذ يجب أن يكون بين 1000 و 65535', 'error');
                return;
            }

            // Get specs based on preset
            let specs;
            if (selectedPreset.value === 'custom') {
                specs = {
                    cpu: parseInt(document.getElementById('specsCpu').value),
                    ram: parseInt(document.getElementById('specsRam').value),
                    storage: parseInt(document.getElementById('specsStorage').value)
                };
            } else {
                specs = specsPresets[selectedPreset.value];
            }

            // Validate specs
            if (specs.cpu < 1 || specs.ram < 128 || specs.storage < 1) {
                showToast('المواصفات غير صحيحة', 'error');
                return;
            }

            // Disable button and show loading
            const btn = document.getElementById('createHostingBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>جاري الإنشاء...';

            // Send request
            const skipTemplateInput = document.getElementById('skipTemplate');
            const skipTemplate = serviceType === 'minecraft' ? !skipTemplateInput.checked : false;

            const requestData = {
                discordId,
                name: hostName || null,
                serviceType,
                port: port || null,
                duration,
                mainFile,
                specs,
                skipTemplate
            };

            console.log('Sending request with data:', requestData);

            fetch('/admin/create-hosting', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestData)
            })
                .then(r => {
                    console.log('Response status:', r.status);
                    return r.json();
                })
                .then(d => {
                    console.log('Response data:', d);
                    if (d.success) {
                        showToast('تم إنشاء الهوست بنجاح! 🎉', 'success');

                        // Reset form
                        document.getElementById('createHostingForm').reset();
                        document.getElementById('customSpecs').style.display = 'none';
