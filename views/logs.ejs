    <script>
        let currentPage = 1;
        let totalPages = 1;
        let currentFilters = {};
        let currentView = 'table';
        let terminalHistory = [];
        let terminalHistoryIndex = -1;

        // تحميل السجلات عند بدء الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadStats();
            loadLogs();
            setupTerminal();
            
            // تحديث تلقائي كل 30 ثانية
            setInterval(() => {
                loadStats();
                loadLogs();
                if (currentView === 'terminal') {
                    loadTerminalLogs();
                }
            }, 30000);
        });

        // تحميل الإحصائيات
        async function loadStats() {
            try {
                const response = await fetch('/api/admin/logs/stats');
                const stats = await response.json();
                
                document.getElementById('total-logs').textContent = stats.total || 0;
                document.getElementById('unique-users').textContent = stats.uniqueUsersCount || 0;
                document.getElementById('unique-ips').textContent = stats.uniqueIPsCount || 0;
                document.getElementById('errors-count').textContent = stats.errorsCount || 0;
            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        // تحميل السجلات
        async function loadLogs(page = 1) {
            try {
                document.getElementById('logs-loading').style.display = 'block';
                document.getElementById('logs-content').style.display = 'none';
                document.getElementById('no-logs').style.display = 'none';
                
                const params = new URLSearchParams({
                    page: page,
                    limit: 50,
                    ...currentFilters
                });
                
                const response = await fetch(`/api/admin/logs?${params}`);
                const data = await response.json();
                
                if (data.success) {
                    displayLogs(data.logs);
                    updatePagination(data.pagination);
                } else {
                    showError('خطأ في تحميل السجلات');
                }
            } catch (error) {
                console.error('Error loading logs:', error);
                showError('خطأ في تحميل السجلات');
            } finally {
                document.getElementById('logs-loading').style.display = 'none';
                document.getElementById('logs-content').style.display = 'block';
            }
        }

        // عرض السجلات
        function displayLogs(logs) {
            const tbody = document.getElementById('logs-table-body');
            tbody.innerHTML = '';
            
            if (logs.length === 0) {
                document.getElementById('no-logs').style.display = 'block';
                document.getElementById('logs-content').style.display = 'none';
                return;
            }
            
            logs.forEach(log => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${formatDate(log.timestamp)}</td>
                    <td>
                        <div class="user-info">
                            ${log.userAvatar ? `<img src="${log.userAvatar}" class="user-avatar" alt="Avatar">` : '<i class="fas fa-user-circle" style="font-size: 24px; color: var(--text-secondary);"></i>'}
                            <span class="user-name">${log.username || 'مجهول'}</span>
                        </div>
                    </td>
                    <td>
                        <div class="ip-info">${log.ipAddress}</div>
                    </td>
                    <td>
                        <div class="location-info">${log.city}, ${log.country}</div>
                    </td>
                    <td>
                        <span class="log-action ${log.action}">${getActionText(log.action)}</span>
                    </td>
                    <td>
                        <div class="log-description">${log.description}</div>
                    </td>
                    <td>
                        <span class="log-severity ${log.severity}">${getSeverityText(log.severity)}</span>
                    </td>
                    <td>
                        <span class="log-status ${log.status}">${getStatusText(log.status)}</span>
                    </td>
                    <td>
                        <div class="log-details">
                            ${log.method} ${log.statusCode}
                            ${log.details.duration ? `<br>${log.details.duration}ms` : ''}
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // تحديث التصفح
        function updatePagination(pagination) {
            currentPage = pagination.currentPage;
            totalPages = pagination.totalPages;
            
            const paginationDiv = document.getElementById('pagination');
            const pageInfo = document.getElementById('page-info');
            const prevBtn = document.getElementById('prev-btn');
            const nextBtn = document.getElementById('next-btn');
            
            if (totalPages > 1) {
                paginationDiv.style.display = 'flex';
                pageInfo.textContent = `صفحة ${currentPage} من ${totalPages}`;
                prevBtn.disabled = currentPage <= 1;
                nextBtn.disabled = currentPage >= totalPages;
            } else {
                paginationDiv.style.display = 'none';
            }
        }

        // تغيير الصفحة
        function changePage(direction) {
            const newPage = currentPage + direction;
            if (newPage >= 1 && newPage <= totalPages) {
                loadLogs(newPage);
            }
        }

        // تطبيق الفلاتر
        function applyFilters() {
            currentFilters = {
                search: document.getElementById('search-input').value,
                userId: document.getElementById('user-filter').value,
                ipAddress: document.getElementById('ip-filter').value,
                action: document.getElementById('action-filter').value,
                severity: document.getElementById('severity-filter').value,
                status: document.getElementById('status-filter').value,
                startDate: document.getElementById('start-date').value,
                endDate: document.getElementById('end-date').value
            };
            
            // إزالة القيم الفارغة
            Object.keys(currentFilters).forEach(key => {
                if (!currentFilters[key]) {
                    delete currentFilters[key];
                }
            });
            
            currentPage = 1;
            loadLogs();
        }

        // مسح الفلاتر
        function clearFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('user-filter').value = '';
            document.getElementById('ip-filter').value = '';
            document.getElementById('action-filter').value = '';
            document.getElementById('severity-filter').value = '';
            document.getElementById('status-filter').value = '';
            document.getElementById('start-date').value = '';
            document.getElementById('end-date').value = '';
            
            currentFilters = {};
            currentPage = 1;
            loadLogs();
        }

        // تحديث السجلات
        function refreshLogs() {
            loadStats();
            loadLogs(currentPage);
        }

        // تصدير السجلات
        async function exportLogs(format) {
            try {
                const params = new URLSearchParams({
                    format: format,
                    ...currentFilters
                });
                
                const response = await fetch(`/api/admin/logs/export?${params}`);
                
                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `logs-${new Date().toISOString().split('T')[0]}.${format}`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                } else {
                    showError('خطأ في تصدير السجلات');
                }
            } catch (error) {
                console.error('Error exporting logs:', error);
                showError('خطأ في تصدير السجلات');
            }
        }

        // مسح السجلات القديمة
        async function clearOldLogs() {
            if (!confirm('هل أنت متأكد من مسح السجلات القديمة (أكثر من 30 يوم)؟')) {
                return;
            }
            
            try {
                const response = await fetch('/api/admin/logs/clear-old', {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showSuccess(`تم مسح ${result.deletedCount} سجل قديم`);
                    refreshLogs();
                } else {
                    showError('خطأ في مسح السجلات القديمة');
                }
            } catch (error) {
                console.error('Error clearing old logs:', error);
                showError('خطأ في مسح السجلات القديمة');
            }
        }

        // دوال مساعدة
        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleString('ar-SA', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
        }

        function getActionText(action) {
            const actions = {
                'login': 'دخول',
                'logout': 'خروج',
                'hosting_create': 'إنشاء استضافة',
                'hosting_delete': 'حذف استضافة',
                'hosting_start': 'تشغيل',
                'hosting_stop': 'إيقاف',
                'hosting_restart': 'إعادة تشغيل',
                'file_upload': 'رفع ملف',
                'file_delete': 'حذف ملف',
                'file_edit': 'تعديل ملف',
                'file_download': 'تحميل ملف',
                'console_command': 'أمر كونسل',
                'payment_success': 'دفع ناجح',
                'payment_failed': 'دفع فاشل',
                'admin_action': 'عمل إداري',
                'user_ban': 'حظر',
                'user_unban': 'إلغاء حظر',
                'api_call': 'API',
                'error': 'خطأ',
                'page_visit': 'زيارة صفحة'
            };
            return actions[action] || action;
        }

        function getSeverityText(severity) {
            const severities = {
                'info': 'معلومات',
                'warning': 'تحذير',
                'error': 'خطأ',
                'critical': 'حرج'
            };
            return severities[severity] || severity;
        }

        function getStatusText(status) {
            const statuses = {
                'success': 'نجح',
                'failed': 'فشل',
                'pending': 'في الانتظار'
            };
            return statuses[status] || status;
        }

        function showSuccess(message) {
            // يمكن إضافة toast notification هنا
            alert('✅ ' + message);
        }

        function showError(message) {
            // يمكن إضافة toast notification هنا
            alert('❌ ' + message);
        }

        // Terminal Functions
        function switchView(view) {
            currentView = view;
            
            // Update buttons
            document.getElementById('table-view-btn').classList.toggle('active', view === 'table');
            document.getElementById('terminal-view-btn').classList.toggle('active', view === 'terminal');
            
            // Show/hide views
            document.getElementById('table-view').style.display = view === 'table' ? 'block' : 'none';
            document.getElementById('terminal-view').style.display = view === 'terminal' ? 'block' : 'none';
            
            if (view === 'terminal') {
                loadTerminalLogs();
            }
        }

        function setupTerminal() {
            const terminalInput = document.getElementById('terminal-input');
            
            terminalInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    executeTerminalCommand(this.value);
                    this.value = '';
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (terminalHistoryIndex > 0) {
                        terminalHistoryIndex--;
                        this.value = terminalHistory[terminalHistoryIndex];
                    }
                } else if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (terminalHistoryIndex < terminalHistory.length - 1) {
                        terminalHistoryIndex++;
                        this.value = terminalHistory[terminalHistoryIndex];
                    } else {
                        terminalHistoryIndex = terminalHistory.length;
                        this.value = '';
                    }
                }
            });
        }

        async function executeTerminalCommand(command) {
            if (!command.trim()) return;
            
            // Add to history
            terminalHistory.push(command);
            terminalHistoryIndex = terminalHistory.length;
            
            // Show command
            addTerminalLine(`$ ${command}`, 'command');
            
            // Parse command
            const parts = command.trim().split(' ');
            const cmd = parts[0].toLowerCase();
            
            switch (cmd) {
                case 'help':
                    showTerminalHelp();
                    break;
                case 'clear':
                    clearTerminal();
                    break;
                case 'search':
                    const searchTerm = parts.slice(1).join(' ');
                    searchTerminalLogs(searchTerm);
                    break;
                case 'filter':
                    const filterType = parts[1];
                    const filterValue = parts.slice(2).join(' ');
                    filterTerminalLogs(filterType, filterValue);
                    break;
                case 'stats':
                    showTerminalStats();
                    break;
                case 'recent':
                    const limit = parts[1] ? parseInt(parts[1]) : 10;
                    loadTerminalLogs(limit);
                    break;
                default:
                    addTerminalLine(`Command not found: ${cmd}. Type 'help' for available commands.`, 'error');
            }
        }

        function addTerminalLine(text, type = 'normal') {
            const terminalOutput = document.getElementById('terminal-output');
            const line = document.createElement('div');
            line.className = `terminal-line terminal-log ${type}`;
            
            if (type === 'command') {
                line.innerHTML = `<span class="terminal-prompt">$</span><span class="terminal-text">${text}</span>`;
            } else {
                line.innerHTML = `<span class="terminal-text">${text}</span>`;
            }
            
            terminalOutput.appendChild(line);
            terminalOutput.scrollTop = terminalOutput.scrollHeight;
        }

        function clearTerminal() {
            const terminalOutput = document.getElementById('terminal-output');
            terminalOutput.innerHTML = '';
        }

        function showTerminalHelp() {
            const helpText = `
Available commands:
  help                    - Show this help message
  clear                   - Clear terminal output
  search <term>           - Search in logs
  filter <type> <value>   - Filter logs (user, ip, action, severity)
  stats                   - Show statistics
  recent [limit]          - Show recent logs (default: 10)
            `.trim();
            
            addTerminalLine(helpText, 'info');
        }

        async function loadTerminalLogs(limit = 50) {
            try {
                const params = new URLSearchParams({
                    limit: limit,
                    ...currentFilters
                });
                
                const response = await fetch(`/api/admin/logs?${params}`);
                const data = await response.json();
                
                if (data.success && data.logs.length > 0) {
                    clearTerminal();
                    data.logs.forEach(log => {
                        displayTerminalLog(log);
                    });
                } else {
                    addTerminalLine('No logs found', 'info');
                }
            } catch (error) {
                addTerminalLine(`Error loading logs: ${error.message}`, 'error');
            }
        }

        function displayTerminalLog(log) {
            const timestamp = new Date(log.timestamp).toLocaleString('ar-SA');
            const user = log.username || 'مجهول';
            const ip = log.ipAddress;
            const action = getActionText(log.action);
            const description = log.description;
            const severity = log.severity;
            
            const logLine = `[${timestamp}] ${user}@${ip} - ${action}: ${description}`;
            addTerminalLine(logLine, severity);
        }

        async function searchTerminalLogs(searchTerm) {
            if (!searchTerm) {
                addTerminalLine('Please provide a search term', 'error');
                return;
            }
            
            try {
                const params = new URLSearchParams({
                    search: searchTerm,
                    limit: 50
                });
                
                const response = await fetch(`/api/admin/logs?${params}`);
                const data = await response.json();
                
                if (data.success && data.logs.length > 0) {
                    clearTerminal();
                    addTerminalLine(`Search results for: ${searchTerm}`, 'info');
                    data.logs.forEach(log => {
                        displayTerminalLog(log);
                    });
                } else {
                    addTerminalLine(`No results found for: ${searchTerm}`, 'info');
                }
            } catch (error) {
                addTerminalLine(`Search error: ${error.message}`, 'error');
            }
        }

        async function filterTerminalLogs(filterType, filterValue) {
            if (!filterType || !filterValue) {
                addTerminalLine('Usage: filter <type> <value>', 'error');
                return;
            }
            
            try {
                const params = new URLSearchParams({
                    [filterType]: filterValue,
                    limit: 50
                });
                
                const response = await fetch(`/api/admin/logs?${params}`);
                const data = await response.json();
                
                if (data.success && data.logs.length > 0) {
                    clearTerminal();
                    addTerminalLine(`Filtered by ${filterType}: ${filterValue}`, 'info');
                    data.logs.forEach(log => {
                        displayTerminalLog(log);
                    });
                } else {
                    addTerminalLine(`No results found for ${filterType}: ${filterValue}`, 'info');
                }
            } catch (error) {
                addTerminalLine(`Filter error: ${error.message}`, 'error');
            }
        }

        async function showTerminalStats() {
            try {
                const response = await fetch('/api/admin/logs/stats');
                const stats = await response.json();
                
                const statsText = `
Statistics:
  Total Logs: ${stats.total || 0}
  Unique Users: ${stats.uniqueUsersCount || 0}
  Unique IPs: ${stats.uniqueIPsCount || 0}
  Errors: ${stats.errorsCount || 0}
                `.trim();
                
                addTerminalLine(statsText, 'info');
            } catch (error) {
                addTerminalLine(`Stats error: ${error.message}`, 'error');
            }
        }
    </script>
</div>
