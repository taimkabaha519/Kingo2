<div class="admin-page fade-in">
    <div class="container-fluid">
        <div class="admin-header">
            <h2 class="slide-up"><i class="fas fa-shield-halved me-2"></i> لوحة الإدارة</h2>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" onclick="openCreateHostingModal()">
                    <i class="fas fa-plus me-1"></i> إضافة هوست
                </button>
                <a href="/admin/hostings-control" class="btn btn-info">
                    <i class="fas fa-cogs me-1"></i> تحكم بالهوستات
                </a>
                <% if (isOwner) { %>
                    <a href="/admin/logs" class="btn btn-secondary">
                        <i class="fas fa-clipboard-list me-1"></i> سجلات الموقع
                    </a>
                    <% } %>
            </div>
        </div>

        <div class="admin-tabs">
            <div class="admin-tab active" data-target="dashboard-section">
                <i class="fas fa-tachometer-alt me-1"></i> لوحة المعلومات
            </div>
            <div class="admin-tab" data-target="hostings-section">
                <i class="fas fa-server me-1"></i> إدارة الهوستات
            </div>
            <div class="admin-tab" data-target="minecraft-section">
                <i class="fas fa-cube me-1"></i> سيرفرات Minecraft
            </div>
            <div class="admin-tab" data-target="security-section">
                <i class="fas fa-shield-alt me-1"></i> الأمان
            </div>
            <div class="admin-tab" data-target="tickets-section">
                <i class="fas fa-ticket-alt me-1"></i> التذاكر
            </div>
            <div class="admin-tab" data-target="tools-section">
                <i class="fas fa-tools me-1"></i> الأدوات
            </div>
            <div class="admin-tab" data-target="notifications-section">
                <i class="fas fa-bell me-1"></i> الإشعارات
            </div>
            <% if (isOwner) { %>
                <div class="admin-tab" data-target="pricing-section">
                    <i class="fas fa-dollar-sign me-1"></i> الباقات والأسعار
                </div>
                <div class="admin-tab" data-target="logs-section">
                    <i class="fas fa-clipboard-list me-1"></i> سجلات الموقع
                </div>
                <% } %>
        </div>

        <!-- Dashboard Section -->
        <div class="admin-section active" id="dashboard-section">
            <div class="row">
                <!-- Stats Cards -->
                <% if (typeof stats !=='undefined' ) { %>
                    <div class="grid grid-4 mb-4 slide-up">
                        <div class="card card-clickable" onclick="showHostingsList()">
                            <div class="card-icon"><i class="fas fa-server"></i></div>
                            <h4 class="mb-1">
                                <%= stats.totalHostings %>
                            </h4>
                            <p>إجمالي الهوستات</p>
                            <div class="card-badge"><i class="fas fa-chevron-right"></i></div>
                        </div>
                        <div class="card card-clickable" onclick="filterHostings('running')">
                            <div class="card-icon"><i class="fas fa-play-circle"></i></div>
                            <h4 class="mb-1">
                                <%= stats.activeHostings %>
                            </h4>
                            <p>الهوستات النشطة</p>
                            <div class="card-badge bg-success"><i class="fas fa-chevron-right"></i></div>
                        </div>
                        <div class="card card-clickable" onclick="showUsersList()">
                            <div class="card-icon"><i class="fas fa-users"></i></div>
                            <h4 class="mb-1">
                                <%= stats.totalUsers %>
                            </h4>
                            <p>المستخدمين</p>
                            <div class="card-badge"><i class="fas fa-chevron-right"></i></div>
                        </div>
                        <div class="card card-clickable" onclick="optimizeStorage()">
                            <div class="card-icon"><i class="fas fa-hdd"></i></div>
                            <h4 class="mb-1">
                                <%= stats.totalStorage %>
                            </h4>
                            <p>المساحة المستخدمة</p>
                            <div class="card-badge"><i class="fas fa-broom"></i></div>
                        </div>
                    </div>
                    <div class="grid grid-4 mb-4 slide-up" style="animation-delay: 0.15s;">
                        <div class="card card-clickable" onclick="filterHostings('discord')">
                            <div class="card-icon"><i class="fab fa-discord"></i></div>
                            <h4 class="mb-1">
                                <%= (hostings||[]).filter(h=> h.serviceType === 'discord').length %>
                            </h4>
                            <p>بوتات ديسكورد</p>
                        </div>
                        <div class="card card-clickable" onclick="filterHostings('web')">
                            <div class="card-icon"><i class="fas fa-globe"></i></div>
                            <h4 class="mb-1">
                                <%= (hostings||[]).filter(h=> h.serviceType === 'web').length %>
                            </h4>
                            <p>مواقع ويب</p>
                        </div>
                        <div class="card card-clickable" onclick="filterHostings('mta')">
                            <div class="card-icon"><i class="fas fa-gamepad"></i></div>
                            <h4 class="mb-1">
                                <%= (hostings||[]).filter(h=> h.serviceType === 'mta' || h.serviceType ===
                                    'fivem').length %>
                            </h4>
                            <p>سيرفرات ألعاب</p>
                        </div>
                    </div>
                    <% } %>

                        <div class="row mt-4 slide-up" style="animation-delay: 0.1s;">
                            <div class="col-md-12">
                                <div class="card" id="tools-card">
                                    <div class="card-header">
                                        <h4 class="mb-0"><i class="fas fa-gear me-1"></i> أدوات سريعة</h4>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex flex-wrap gap-2">
                                            <button id="optimize-storage" class="btn btn-primary"><i
                                                    class="fas fa-broom me-1"></i> تخفيف المساحة</button>
                                        </div>
                                        <div id="optimize-result" class="text-muted small mt-2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
            </div>
        </div>

        <!-- Security Section -->
        <div class="container-fluid">
            <div class="admin-section" id="security-section">
                <h3 class="section-title mb-4"><i class="fas fa-shield-alt me-2"></i> إدارة الأمان</h3>

                <div class="security-section">
                    <!-- IP Ban Card -->
                    <div class="card security-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="card-icon">
                                    <i class="fas fa-network-wired"></i>
                                </div>
                                <h4 class="mb-0">حظر عنوان IP</h4>
                            </div>
                            <button class="btn btn-sm btn-outline" onclick="refreshBannedIps()"
                                data-tooltip="تحديث قائمة IP المحظورة"><i class="fas fa-sync"></i></button>
                        </div>
                        <div class="card-body">
                            <div class="input-group input-group-enhanced mb-3">
                                <input id="ban-ip-input" class="form-control" placeholder="أدخل IP للحظر">
                                <button class="btn btn-danger" onclick="banIp()"><i class="fas fa-ban me-1"></i>
                                    حظر</button>
                            </div>
                            <div class="banned-ips-list mb-3">
                                <h6 class="small">عناوين IP المحظورة:</h6>
                                <div id="banned-ips-container" class="mt-2">
                                    <% if ((bannedIps||[]).length===0) { %>
                                        <div class="text-muted">لا توجد عناوين IP محظورة</div>
                                        <% } else { %>
                                            <% (bannedIps||[]).forEach(ip=> { %>
                                                <div class="banned-ip-item">
                                                    <span>
                                                        <%= ip %>
                                                    </span>
                                                    <button class="btn btn-sm btn-outline"
                                                        onclick="unbanIpDirect('<%= ip %>')"><i
                                                            class="fas fa-times"></i></button>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- User Ban Card -->
                    <div class="card security-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="card-icon">
                                    <i class="fas fa-user-slash"></i>
                                </div>
                                <h4 class="mb-0">حظر مستخدم</h4>
                            </div>
                            <button class="btn btn-sm btn-outline" onclick="refreshBannedUsers()"
                                data-tooltip="تحديث قائمة المستخدمين المحظورين"><i class="fas fa-sync"></i></button>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="input-group input-group-enhanced mb-2">
                                    <input id="ban-user-id-input" class="form-control" placeholder="أدخل معرف المستخدم">
                                    <button class="btn btn-danger" onclick="banUser()"><i class="fas fa-ban me-1"></i>
                                        حظر</button>
                                </div>
                                <div class="input-group input-group-enhanced">
                                    <input id="ban-user-name-input" class="form-control"
                                        placeholder="اسم المستخدم (اختياري)">
                                </div>
                            </div>
                            <div class="banned-users-list mb-2">
                                <h6 class="small">المستخدمين المحظورين:</h6>
                                <div id="banned-users-container" class="mt-2">
                                    <div class="text-muted">لا توجد معرفات محظورة</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tickets Section -->
        <div class="container-fluid">
            <div class="admin-section" id="tickets-section">
                <h3 class="section-title mb-4"><i class="fas fa-ticket-alt me-2"></i> إدارة التذاكر</h3>

                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="fas fa-inbox me-1"></i> جميع التذاكر</h4>
                    </div>
                    <div class="card-body">
                        <% if (tickets && tickets.length) { %>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>الموضوع</th>
                                            <th>المستخدم</th>
                                            <th>الحالة</th>
                                            <th>تاريخ</th>
                                            <th>إجراءات</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% tickets.forEach(t=> { %>
                                            <tr>
                                                <td><strong>
                                                        <%= t.subject %>
                                                    </strong>
                                                    <div class="text-muted small">
                                                        <%= t.type %>
                                                    </div>
                                                </td>
                                                <td class="text-capitalize">
                                                    <%= t.user?.username || 'guest' %>
                                                </td>
                                                <td><span
                                                        class="badge <%= t.status==='open'?'bg-success':t.status==='pending'?'bg-dark':'bg-danger' %>">
                                                        <%= t.status %>
                                                    </span></td>
                                                <td>
                                                    <%= new Date(t.createdAt).toLocaleString('ar-EG') %>
                                                </td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-sm"
                                                            onclick="updateTicket('<%= t.id %>','open')">فتح</button>
                                                        <button class="btn btn-sm"
                                                            onclick="updateTicket('<%= t.id %>','pending')">قيد
                                                            المراجعة</button>
                                                        <button class="btn btn-sm btn-danger"
                                                            onclick="updateTicket('<%= t.id %>','closed')">إغلاق</button>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } else { %>
                                <div class="text-center py-4 text-muted">لا توجد تذاكر</div>
                                <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tools Section -->
        <div class="container-fluid">
            <div class="admin-section" id="tools-section">
                <h3 class="section-title mb-4"><i class="fas fa-tools me-2"></i> أدوات النظام</h3>

                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="fas fa-broom me-1"></i> تحسين النظام</h4>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-3">
                            <button id="optimize-storage-tool" class="btn btn-primary"
                                data-tooltip="حذف الملفات المؤقتة وتوفير المساحة">
                                <i class="fas fa-broom me-1"></i> تخفيف المساحة
                            </button>
                            <button class="btn btn-outline" onclick="cleanupDatabase()"
                                data-tooltip="حذف السجلات القديمة من قاعدة البيانات">
                                <i class="fas fa-database me-1"></i> تنظيف قاعدة البيانات
                            </button>
                            <button class="btn btn-outline" onclick="cleanupLogs()"
                                data-tooltip="حذف ملفات السجلات القديمة">
                                <i class="fas fa-history me-1"></i> تنظيف السجلات
                            </button>
                        </div>
                        <div id="optimize-result-tool" class="text-muted small mt-3 p-3 bg-dark rounded"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing Section -->
        <div class="container-fluid">
            <div class="admin-section" id="pricing-section">
                <h3 class="section-title mb-4"><i class="fas fa-dollar-sign me-2"></i> إدارة الباقات والأسعار</h3>

                <div class="row">
                    <!-- Packages Management -->
                    <div class="col-md-12 mb-4">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h4 class="mb-0"><i class="fas fa-box me-1"></i> الباقات والأسعار</h4>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline" onclick="loadPricingConfig()">
                                        <i class="fas fa-sync me-1"></i> تحديث
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <ul class="nav nav-tabs mb-3" id="serviceTypeTabs" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="discord-tab" data-bs-toggle="tab"
                                            data-bs-target="#discord-packages" type="button" role="tab">
                                            <i class="fab fa-discord me-1"></i> Discord
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="web-tab" data-bs-toggle="tab"
                                            data-bs-target="#web-packages" type="button" role="tab">
                                            <i class="fas fa-globe me-1"></i> Web
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="minecraft-tab" data-bs-toggle="tab"
                                            data-bs-target="#minecraft-packages" type="button" role="tab">
                                            <i class="fas fa-cube me-1"></i> Minecraft
                                        </button>
                                    </li>
                                </ul>

                                <div class="tab-content" id="serviceTypeTabContent">
                                    <!-- Discord Packages -->
                                    <div class="tab-pane fade show active" id="discord-packages" role="tabpanel">
                                        <div id="discord-packages-container">
                                            <!-- Packages will be loaded here -->
                                        </div>
                                        <button class="btn btn-primary mt-3" onclick="addPackage('discord')">
                                            <i class="fas fa-plus me-1"></i> إضافة باقة جديدة
                                        </button>
                                    </div>

                                    <!-- Web Packages -->
                                    <div class="tab-pane fade" id="web-packages" role="tabpanel">
                                        <div id="web-packages-container">
                                            <!-- Packages will be loaded here -->
                                        </div>
                                        <button class="btn btn-primary mt-3" onclick="addPackage('web')">
                                            <i class="fas fa-plus me-1"></i> إضافة باقة جديدة
                                        </button>
                                    </div>

                                    <!-- Minecraft Packages -->
                                    <div class="tab-pane fade" id="minecraft-packages" role="tabpanel">
                                        <div id="minecraft-packages-container">
                                            <!-- Packages will be loaded here -->
                                        </div>
                                        <button class="btn btn-primary mt-3" onclick="addPackage('minecraft')">
                                            <i class="fas fa-plus me-1"></i> إضافة باقة جديدة
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Discount Codes -->
                    <div class="col-md-12 mb-4">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h4 class="mb-0"><i class="fas fa-ticket-alt me-1"></i> أكواد الخصم</h4>
                                <button class="btn btn-primary btn-sm" onclick="openAddDiscountCodeModal()">
                                    <i class="fas fa-plus me-1"></i> إضافة كود خصم
                                </button>
                            </div>
                            <div class="card-body">
                                <div id="discount-codes-container">
                                    <!-- Discount codes will be loaded here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Minecraft Section -->
        <div class="container-fluid">
            <div class="admin-section" id="minecraft-section">
                <h3 class="section-title mb-4"><i class="fas fa-cube me-2"></i> إدارة سيرفرات Minecraft</h3>

                <div class="row mb-4">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h4 class="mb-0"><i class="fas fa-server me-1"></i> سيرفرات Minecraft النشطة</h4>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline" onclick="refreshMinecraftServers()">
                                        <i class="fas fa-sync me-1"></i> تحديث
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <div id="minecraft-servers-container">
                                    <!-- Minecraft servers will be loaded here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Giveaways Section -->
        <div class="container-fluid">
            <div class="admin-section" id="giveaways-section">
                <h3 class="section-title mb-4"><i class="fas fa-gift me-2"></i> إدارة الجوائز</h3>

                <div class="row">
                    <div class="col-md-12 mb-4">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h4 class="mb-0"><i class="fas fa-gift me-1"></i> الجوائز النشطة</h4>
                                <button class="btn btn-primary btn-sm" onclick="openCreateGiveawayModal()">
                                    <i class="fas fa-plus me-1"></i> إنشاء جائزة جديدة
                                </button>
                            </div>
                            <div class="card-body">
                                <div id="giveaways-container">
                                    <!-- Giveaways will be loaded here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Section -->
        <div class="container-fluid">
            <div class="admin-section" id="notifications-section">
                <h3 class="section-title mb-4"><i class="fas fa-bell me-2"></i> إدارة الإشعارات</h3>

                <div class="notifications-management-section">
                    <!-- Create Notification Card -->
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h4 class="mb-0"><i class="fas fa-plus-circle me-1"></i> إنشاء إشعار جديد</h4>
                            <button class="btn btn-primary" onclick="openCreateNotificationModal()">
                                <i class="fas fa-plus me-1"></i> إضافة إشعار
                            </button>
                        </div>
                    </div>

                    <!-- Notifications List -->
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">
                                <i class="fas fa-list me-1"></i> الإشعارات المرسلة
                                <span class="badge bg-primary ms-2">
                                    <%= notifications ? notifications.length : 0 %>
                                </span>
                            </h4>
                            <button class="btn btn-primary btn-sm" onclick="openCreateNotificationModal()">
                                <i class="fas fa-plus me-1"></i>إنشاء إشعار
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 700px; overflow-y: auto; width: 100%;">
                                <table class="table table-hover mb-0" id="notifications-table"
                                    style="min-width: 1200px;">
                                    <thead class="table-dark sticky-top">
                                        <tr>
                                            <th style="width: 25%;">العنوان</th>
                                            <th style="width: 10%;">النوع</th>
                                            <th style="width: 12%;">المستهدف</th>
                                            <th style="width: 10%;">الأولوية</th>
                                            <th style="width: 15%;">تاريخ الإرسال</th>
                                            <th style="width: 8%;">الحالة</th>
                                            <th style="width: 15%;">إجراءات</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (notifications && notifications.length> 0) { %>
                                            <% notifications.forEach(notification=> { %>
                                                <tr data-notification-id="<%= notification._id %>"
                                                    class="notification-row">
                                                    <td>
                                                        <div class="notification-title fw-bold text-truncate"
                                                            style="max-width: 250px;" title="<%= notification.title %>">
                                                            <%= notification.title %>
                                                        </div>
                                                        <div class="text-muted small text-truncate notification-message"
                                                            style="max-width: 250px;"
                                                            title="<%= notification.message %>">
                                                            <%= notification.message.length> 60 ?
                                                                notification.message.substring(0, 60) + '...' :
                                                                notification.message %>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span class="badge <%= 
                                                    notification.type === 'info' ? 'bg-info' :
                                                    notification.type === 'warning' ? 'bg-warning' :
                                                    notification.type === 'success' ? 'bg-success' :
                                                    notification.type === 'error' ? 'bg-danger' :
                                                    notification.type === 'announcement' ? 'bg-primary' :
                                                    'bg-secondary'
                                                %> notification-type">
                                                            <%= notification.type==='info' ? 'معلومات' :
                                                                notification.type==='warning' ? 'تحذير' :
                                                                notification.type==='success' ? 'نجاح' :
                                                                notification.type==='error' ? 'خطأ' :
                                                                notification.type==='announcement' ? 'إعلان' :
                                                                notification.type %>
                                                        </span>
                                                    </td>
                                                    <td class="notification-target">
                                                        <% if (notification.targetType==='all' ) { %>
                                                            <span class="badge bg-primary">
                                                                <i class="fas fa-globe me-1"></i>الجميع
                                                            </span>
                                                            <% } else { %>
                                                                <span class="badge bg-info">
                                                                    <i class="fas fa-users me-1"></i>
                                                                    <%= notification.targetUsers ?
                                                                        notification.targetUsers.length : 0 %> مستخدم
                                                                </span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <span class="badge <%= 
                                                    notification.priority === 'urgent' ? 'bg-danger' :
                                                    notification.priority === 'high' ? 'bg-warning' :
                                                    notification.priority === 'medium' ? 'bg-info' :
                                                    'bg-secondary'
                                                %> notification-priority">
                                                            <i class="fas fa-<%= 
                                                        notification.priority === 'urgent' ? 'exclamation-triangle' :
                                                        notification.priority === 'high' ? 'arrow-up' :
                                                        notification.priority === 'medium' ? 'minus' : 'arrow-down'
                                                    %> me-1"></i>
                                                            <%= notification.priority==='urgent' ? 'عاجل' :
                                                                notification.priority==='high' ? 'عالي' :
                                                                notification.priority==='medium' ? 'متوسط' : 'منخفض' %>
                                                        </span>
                                                    </td>
                                                    <td class="notification-date">
                                                        <div class="text-muted small">
                                                            <i class="fas fa-clock me-1"></i>
                                                            <%= formatTimeAgo(notification.createdAt) %>
                                                        </div>
                                                        <div class="text-muted" style="font-size: 11px;">
                                                            <%= new
                                                                Date(notification.createdAt).toLocaleDateString('ar-EG')
                                                                %>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <% if (notification.isActive) { %>
                                                            <span class="badge bg-success notification-status">
                                                                <i class="fas fa-check-circle me-1"></i>نشط
                                                            </span>
                                                            <% } else { %>
                                                                <span class="badge bg-secondary notification-status">
                                                                    <i class="fas fa-pause-circle me-1"></i>معلق
                                                                </span>
                                                                <% } %>
                                                    </td>
                                                    <td>
                                                        <div class="dropdown">
                                                            <button
                                                                class="btn btn-sm btn-outline-primary dropdown-toggle"
                                                                type="button"
                                                                id="notificationDropdown<%= notification._id %>"
                                                                onclick="toggleDropdown('notificationDropdown<%= notification._id %>')">
                                                                <i class="fas fa-cog me-1"></i>إجراءات
                                                            </button>
                                                            <ul class="dropdown-menu dropdown-menu-end"
                                                                aria-labelledby="notificationDropdown<%= notification._id %>">
                                                                <li><a class="dropdown-item" href="javascript:void(0)"
                                                                        onclick="viewNotification('<%= notification._id %>')">
                                                                        <i class="fas fa-eye me-2"></i>عرض التفاصيل
                                                                    </a></li>
                                                                <li><a class="dropdown-item" href="javascript:void(0)"
                                                                        onclick="editNotification('<%= notification._id %>')">
                                                                        <i class="fas fa-edit me-2"></i>تعديل
                                                                    </a></li>
                                                                <li>
                                                                    <hr class="dropdown-divider">
                                                                </li>
                                                                <li><a class="dropdown-item" href="javascript:void(0)"
                                                                        onclick="toggleNotificationStatus('<%= notification._id %>', '<%= notification.isActive %>')">
                                                                        <i
                                                                            class="fas fa-<%= notification.isActive ? 'pause' : 'play' %> me-2"></i>
                                                                        <%= notification.isActive ? 'إيقاف' : 'تفعيل' %>
                                                                    </a></li>
                                                                <li><a class="dropdown-item text-danger"
                                                                        href="javascript:void(0)"
                                                                        onclick="deleteNotification('<%= notification._id %>', '<%= notification.title %>')">
                                                                        <i class="fas fa-trash me-2"></i>حذف نهائي
                                                                    </a></li>
                                                            </ul>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="7" class="text-center py-5 text-muted">
                                                                <i
                                                                    class="fas fa-bell-slash fa-3x mb-3 d-block opacity-50"></i>
                                                                <h6>لا توجد إشعارات مرسلة</h6>
                                                                <p class="mb-3">ابدأ بإنشاء إشعار جديد للمستخدمين</p>
                                                                <button class="btn btn-primary"
                                                                    onclick="openCreateNotificationModal()">
                                                                    <i class="fas fa-plus me-1"></i>إنشاء أول إشعار
                                                                </button>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hostings Section -->
        <div class="container-fluid">
            <div class="admin-section" id="hostings-section">
                <h3 class="section-title mb-4"><i class="fas fa-server me-2"></i> إدارة الهوستات</h3>

                <div class="hostings-management-section">
                    <div class="hostings-table-wrapper" id="hostings-table-section">
                        <div class="hostings-table-header">
                            <h4 class="mb-0">قائمة الهوستات</h4>
                            <div class="hostings-filters">
                                <div class="input-group input-group-sm">
                                    <input type="text" class="form-control" id="hostings-search" placeholder="بحث...">
                                    <button class="btn btn-outline" type="button" id="hostings-search-btn">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-sm dropdown-toggle" type="button" id="filterDropdown"
                                        onclick="toggleDropdown('filterDropdown')">
                                        <i class="fas fa-filter me-1"></i> تصفية
                                    </button>
                                    <ul class="dropdown-menu" aria-labelledby="filterDropdown">
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('all'); return false;">الكل</a></li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('running'); return false;">قيد التشغيل</a></li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('stopped'); return false;">متوقف</a></li>
                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('discord'); return false;">بوتات ديسكورد</a>
                                        </li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('web'); return false;">مواقع ويب</a></li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('mta'); return false;">MTA</a></li>
                                        <li><a class="dropdown-item" href="javascript:void(0)"
                                                onclick="filterHostings('fivem'); return false;">FiveM</a></li>
                                    </ul>
                                </div>
                                <button class="btn btn-sm btn-primary" onclick="openCreateHostingModal()">
                                    <i class="fas fa-plus me-1"></i> إضافة
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0" id="hostings-table">
                                    <thead>
                                        <tr>
                                            <th>الاسم</th>
                                            <th>المالك</th>
                                            <th>النوع</th>
                                            <th>المنفذ</th>
                                            <th>المواصفات</th>
                                            <th>الحالة</th>
                                            <th>تاريخ الانتهاء</th>
                                            <th>إجراءات</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% (hostings||[]).forEach(h=> { %>
                                            <tr data-hosting-id="<%= h.id %>" data-hosting-type="<%= h.serviceType %>"
                                                data-hosting-status="<%= h.status||'stopped' %>">
                                                <td>
                                                    <%= h.name %>
                                                </td>
                                                <td class="text-capitalize">
                                                    <%= h.owner?.username || 'unknown' %>
                                                </td>
                                                <td>
                                                    <% if (h.serviceType==='discord' ) { %>
                                                        <span class="badge bg-primary"><i
                                                                class="fab fa-discord me-1"></i> Discord</span>
                                                        <% } else if (h.serviceType==='web' ) { %>
                                                            <span class="badge bg-info"><i
                                                                    class="fas fa-globe me-1"></i> Web</span>
                                                            <% } else if (h.serviceType==='mta' ) { %>
                                                                <span class="badge bg-warning"><i
                                                                        class="fas fa-gamepad me-1"></i> MTA</span>
                                                                <% } else if (h.serviceType==='fivem' ) { %>
                                                                    <span class="badge bg-success"><i
                                                                            class="fas fa-gamepad me-1"></i>
                                                                        FiveM</span>
                                                                    <% } else if (h.serviceType==='minecraft' ) { %>
                                                                        <span class="badge bg-danger"><i
                                                                                class="fas fa-cube me-1"></i>
                                                                            Minecraft</span>
                                                                        <% } else { %>
                                                                            <span class="badge bg-secondary">
                                                                                <%= h.serviceType %>
                                                                            </span>
                                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= h.port || '-' %>
                                                </td>
                                                <td>
                                                    <% if (h.specs) { %>
                                                        <span class="badge bg-dark">
                                                            <%= h.specs.cpu || '1' %> CPU
                                                        </span>
                                                        <span class="badge bg-dark">
                                                            <%= h.specs.ram || '512' %> MB
                                                        </span>
                                                        <span class="badge bg-dark">
                                                            <%= h.specs.storage || '1' %> GB
                                                        </span>
                                                        <% } else { %>
                                                            <span class="badge bg-dark">أساسي</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <% if ((h.status||'stopped')==='running' ) { %>
                                                        <span class="badge bg-success"><i
                                                                class="fas fa-circle me-1"></i> يعمل</span>
                                                        <% } else if ((h.status||'stopped')==='restarting' ) { %>
                                                            <span class="badge bg-warning"><i
                                                                    class="fas fa-sync me-1 fa-spin"></i> إعادة
                                                                تشغيل</span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger"><i
                                                                        class="fas fa-circle me-1"></i> متوقف</span>
                                                                <% } %>
                                                </td>
                                                <td>
                                                    <% if (h.expiryDate) { %>
                                                        <% const now=new Date(); %>
                                                            <% const expiry=new Date(h.expiryDate); %>
                                                                <% const daysLeft=Math.ceil((expiry - now) / (1000 * 60
                                                                    * 60 * 24)); %>
                                                                    <% if (daysLeft <=0) { %>
                                                                        <span class="badge bg-danger"><i
                                                                                class="fas fa-calendar-times me-1"></i>
                                                                            منتهي</span>
                                                                        <% } else if (daysLeft <=3) { %>
                                                                            <span class="badge bg-warning"><i
                                                                                    class="fas fa-exclamation-triangle me-1"></i>
                                                                                <%= daysLeft %> يوم
                                                                            </span>
                                                                            <% } else { %>
                                                                                <span class="badge bg-info"><i
                                                                                        class="fas fa-calendar me-1"></i>
                                                                                    <%= h.expiryDate %>
                                                                                </span>
                                                                                <% } %>
                                                                                    <% } else { %>
                                                                                        <span
                                                                                            class="badge bg-secondary">غير
                                                                                            محدد</span>
                                                                                        <% } %>
                                                </td>
                                                <td>
                                                    <div class="dropdown">
                                                        <button class="btn btn-sm dropdown-toggle" type="button"
                                                            id="dropdownMenuButton<%= h.id %>"
                                                            onclick="toggleDropdown('dropdownMenuButton<%= h.id %>')">
                                                            إجراءات
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end"
                                                            aria-labelledby="dropdownMenuButton<%= h.id %>">
                                                            <li><a class="dropdown-item" href="javascript:void(0)"
                                                                    onclick="adminStart('<%= h.id %>'); return false;"><i
                                                                        class="fas fa-play me-1"></i> تشغيل</a></li>
                                                            <li><a class="dropdown-item" href="javascript:void(0)"
                                                                    onclick="adminStop('<%= h.id %>'); return false;"><i
                                                                        class="fas fa-stop me-1"></i> إيقاف</a></li>
                                                            <li><a class="dropdown-item" href="javascript:void(0)"
                                                                    onclick="adminRestart('<%= h.id %>'); return false;"><i
                                                                        class="fas fa-sync me-1"></i> إعادة تشغيل</a>
                                                            </li>
                                                            <li>
                                                                <hr class="dropdown-divider">
                                                            </li>
                                                            <li><a class="dropdown-item" href="/files/<%= h.id %>"
                                                                    target="_blank"><i
                                                                        class="fas fa-folder-open me-1"></i> الملفات</a>
                                                            </li>
                                                            <li><a class="dropdown-item" href="/console/<%= h.id %>"
                                                                    target="_blank"><i class="fas fa-terminal me-1"></i>
                                                                    الكونسول</a></li>
                                                            <li>
                                                                <hr class="dropdown-divider">
                                                            </li>
                                                            <li><a class="dropdown-item" href="javascript:void(0)"
                                                                    onclick="editHosting('<%= h.id %>', '<%= h.name %>', '<%= h.serviceType %>', '<%= h.port %>', '<%= h.mainFile %>'); return false;"><i
                                                                        class="fas fa-edit me-1"></i> تعديل</a></li>
                                                            <li><a class="dropdown-item" href="javascript:void(0)"
                                                                    onclick="extendHosting('<%= h.id %>', '<%= h.name %>'); return false;"><i
                                                                        class="fas fa-calendar-plus me-1"></i> تمديد</a>
                                                            </li>
                                                            <li><a class="dropdown-item text-danger"
                                                                    href="javascript:void(0)"
                                                                    onclick="confirmDelete('<%= h.id %>', '<%= h.name %>'); return false;"><i
                                                                        class="fas fa-trash me-1"></i> حذف</a></li>
                                                        </ul>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Notification Modal -->
    <div id="createNotificationModal" class="modal-overlay" style="display: none;">
        <div class="modal-container">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-bell me-2"></i>إنشاء إشعار جديد
                </h5>
                <button type="button" class="modal-close" onclick="closeCreateNotificationModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="createNotificationForm">
                    <div class="row">
                        <!-- Basic Information -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-1"></i>معلومات الإشعار
                            </h6>

                            <div class="mb-3">
                                <label for="notificationTitle" class="form-label">
                                    <i class="fas fa-heading me-1"></i>عنوان الإشعار
                                </label>
                                <input type="text" class="form-control" id="notificationTitle"
                                    placeholder="أدخل عنوان الإشعار" required maxlength="200">
                                <div class="form-text">العنوان الذي سيظهر للمستخدمين</div>
                            </div>

                            <div class="mb-3">
                                <label for="notificationMessage" class="form-label">
                                    <i class="fas fa-comment me-1"></i>محتوى الإشعار
                                </label>
                                <textarea class="form-control" id="notificationMessage" rows="4"
                                    placeholder="أدخل محتوى الإشعار" required maxlength="1000"></textarea>
                                <div class="form-text">المحتوى التفصيلي للإشعار</div>
                            </div>

                            <div class="mb-3">
                                <label for="notificationType" class="form-label">
                                    <i class="fas fa-tag me-1"></i>نوع الإشعار
                                </label>
                                <select class="form-select" id="notificationType" required>
                                    <option value="">اختر نوع الإشعار</option>
                                    <option value="info">📢 معلومات</option>
                                    <option value="warning">⚠️ تحذير</option>
                                    <option value="success">✅ نجاح</option>
                                    <option value="error">❌ خطأ</option>
                                    <option value="announcement">📢 إعلان</option>
                                </select>
                            </div>
                        </div>

                        <!-- Target and Settings -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-users me-1"></i>الإعدادات
                            </h6>

                            <div class="mb-3">
                                <label class="form-label">
                                    <i class="fas fa-bullseye me-1"></i>المستهدف
                                </label>
                                <div class="btn-group w-100 mb-2" role="group">
                                    <input type="radio" class="btn-check" name="targetType" id="targetAll" value="all"
                                        checked>
                                    <label class="btn btn-outline-primary" for="targetAll">الجميع</label>

                                    <input type="radio" class="btn-check" name="targetType" id="targetSpecific"
                                        value="specific">
                                    <label class="btn btn-outline-primary" for="targetSpecific">مستخدمين محددين</label>
                                </div>
                            </div>

                            <div id="specificUsersSection" class="mb-3" style="display: none;">
                                <label for="targetUsers" class="form-label">
                                    <i class="fas fa-user-friends me-1"></i>المستخدمين المستهدفين
                                </label>
                                <input type="text" class="form-control" id="targetUsers"
                                    placeholder="أدخل أسماء المستخدمين مفصولة بفاصلة">
                                <div class="form-text">مثال: user1, user2, user3</div>
                            </div>

                            <div class="mb-3">
                                <label for="notificationPriority" class="form-label">
                                    <i class="fas fa-exclamation-triangle me-1"></i>الأولوية
                                </label>
                                <select class="form-select" id="notificationPriority">
                                    <option value="low">🟢 منخفض</option>
                                    <option value="medium" selected>🟡 متوسط</option>
                                    <option value="high">🟠 عالي</option>
                                    <option value="urgent">🔴 عاجل</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="notificationLink" class="form-label">
                                    <i class="fas fa-link me-1"></i>رابط (اختياري)
                                </label>
                                <input type="url" class="form-control" id="notificationLink"
                                    placeholder="https://example.com">
                                <div class="form-text">رابط سيتم فتحه عند النقر على الإشعار</div>
                            </div>

                            <div class="mb-3">
                                <label for="notificationExpiry" class="form-label">
                                    <i class="fas fa-clock me-1"></i>انتهاء الصلاحية (اختياري)
                                </label>
                                <input type="datetime-local" class="form-control" id="notificationExpiry">
                                <div class="form-text">تاريخ انتهاء صلاحية الإشعار</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeCreateNotificationModal()">
                    <i class="fas fa-times me-1"></i>إلغاء
                </button>
                <button type="button" class="btn btn-primary" id="createNotificationBtn">
                    <i class="fas fa-paper-plane me-1"></i>إرسال الإشعار
                </button>
            </div>
        </div>
    </div>

    <!-- Create Hosting Modal -->
    <div id="createHostingModal" class="modal-overlay" style="display: none;">
        <div class="modal-container" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-plus-circle me-2"></i>إضافة هوست جديد
                </h5>
                <button type="button" class="modal-close" onclick="closeCreateHostingModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="createHostingForm" onclick="event.stopPropagation()">
                    <div class="row">
                        <!-- Basic Information -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-1"></i>المعلومات الأساسية
                            </h6>

                            <div class="mb-3">
                                <label for="discordId" class="form-label">
                                    <i class="fas fa-id-card me-1"></i>معرف المستخدم
                                </label>
                                <input type="text" class="form-control" id="discordId"
                                    placeholder="أدخل معرف المستخدم في Discord" required>
                                <div class="form-text">معرف المستخدم في Discord (User ID)</div>
                            </div>

                            <div class="mb-3">
                                <label for="hostName" class="form-label">
                                    <i class="fas fa-server me-1"></i>اسم الهوست (اختياري)
                                </label>
                                <input type="text" class="form-control" id="hostName"
                                    placeholder="اتركه فارغاً للتسمية التلقائية">
                                <div class="form-text">يمكنك تحديد اسم مخصص للهوست أو تركه للتسمية التلقائية</div>
                            </div>

                            <div class="mb-3">
                                <label for="serviceType" class="form-label">
                                    <i class="fas fa-cog me-1"></i>نوع الخدمة
                                </label>
                                <select class="form-select" id="serviceType" required
                                    onchange="toggleMinecraftOptions()">
                                    <option value="">اختر نوع الخدمة</option>
                                    <option value="discord">🤖 Discord Bot</option>
                                    <option value="web">🌐 Web Hosting</option>
                                    <option value="mta">🎮 MTA Server</option>
                                    <option value="fivem">🚗 FiveM Server</option>
                                    <option value="minecraft">🎮 Minecraft Server</option>
                                </select>
                            </div>

                            <div id="minecraftOptions" class="mb-3" style="display: none;">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="skipTemplate" checked>
                                    <label class="form-check-label" for="skipTemplate">
                                        تجهيز ملفات الماينكرافت تلقائياً (jar, eula, properties)
                                    </label>
                                </div>
                                <div class="form-text">قم بإلغاء التحديد إذا كنت تريد الهوست فارغاً تماماً</div>
                            </div>

                            <div class="mb-3">
                                <label for="port" class="form-label">
                                    <i class="fas fa-network-wired me-1"></i>المنفذ (اختياري)
                                </label>
                                <input type="number" class="form-control" id="port" placeholder="3000" min="1000"
                                    max="65535">
                                <div class="form-text">اتركه فارغاً للاختيار التلقائي</div>
                            </div>
                        </div>

                        <!-- Configuration -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-sliders-h me-1"></i>الإعدادات
                            </h6>

                            <div class="mb-3">
                                <label for="duration" class="form-label">
                                    <i class="fas fa-clock me-1"></i>مدة الاستضافة
                                </label>
                                <select class="form-select" id="duration" required>
                                    <option value="">اختر المدة</option>
                                    <option value="3_days">3 أيام - مجاني</option>
                                    <option value="1_week">أسبوع واحد</option>
                                    <option value="1_month">شهر واحد</option>
                                    <option value="3_months">3 شهور</option>
                                    <option value="1_year">سنة كاملة</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="mainFile" class="form-label">
                                    <i class="fas fa-file-code me-1"></i>الملف الرئيسي
