        function addPackage(serviceType) {
            fetch('/api/admin/pricing-config')
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const packages = data.prices[serviceType] || [];
                        packages.push({ name: 'New Package', price: 0, ram: 512, cpu: 1, storage: 1, duration: 30 });
                        renderPackages(serviceType, packages);
                    }
                })
                .catch(err => console.error('Error:', err));
