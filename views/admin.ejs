            fetch('/api/admin/end-giveaway', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showToast('تم إنهاء الجائزة بنجاح', 'success');
                        loadGiveaways();
                    } else {
                        showToast('فشل الإنهاء: ' + (data.message || ''), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    showToast('خطأ في الاتصال', 'error');
                });
        }

        function deleteGiveaway(id) {
            if (!confirm('هل أنت متأكد من حذف هذه الجائزة؟')) return;

            fetch('/api/admin/delete-giveaway', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showToast('تم حذف الجائزة بنجاح', 'success');
                        loadGiveaways();
                    } else {
                        showToast('فشل الحذف: ' + (data.message || ''), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    showToast('خطأ في الاتصال', 'error');
                });
        }

        // Minecraft Servers Management Functions
        function loadMinecraftServers() {
            fetch('/api/admin/minecraft-servers')
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        renderMinecraftServers(data.servers || []);
                    }
                })
                .catch(err => {
                    console.error('Error loading Minecraft servers:', err);
                    const container = document.getElementById('minecraft-servers-container');
                    if (container) {
                        container.innerHTML = '<p class="text-muted text-center py-4">خطأ في تحميل السيرفرات</p>';
                    }
                });
        }

        function renderMinecraftServers(servers) {
            const container = document.getElementById('minecraft-servers-container');
            if (!container) return;

            if (servers.length === 0) {
                container.innerHTML = '<p class="text-muted text-center py-4">لا توجد سيرفرات Minecraft نشطة</p>';
                return;
            }

            container.innerHTML = servers.map(server => {
                const statusBadge = server.status === 'running'
                    ? '<span class="badge bg-success">نشط</span>'
                    : '<span class="badge bg-danger">متوقف</span>';

                const expiryDate = server.expiryDate ? new Date(server.expiryDate).toLocaleDateString('ar-EG') : 'غير محدد';
                const isExpired = server.expiryDate ? new Date(server.expiryDate) < new Date() : false;
                const expiryBadge = isExpired
                    ? '<span class="badge bg-danger">منتهي</span>'
                    : '<span class="badge bg-success">نشط</span>';

                return `
            <div class="card mb-3 minecraft-server-item" data-id="${server.id}">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <h5 class="mb-1">${server.name || 'غير محدد'}</h5>
                            <p class="text-muted small mb-0">المالك: ${server.owner?.username || 'غير محدد'}</p>
                        </div>
                        <div class="col-md-2">
                            <div class="small text-muted">الحالة</div>
                            ${statusBadge}
                        </div>
                        <div class="col-md-2">
                            <div class="small text-muted">المنفذ</div>
                            <strong>${server.port || 'غير محدد'}</strong>
                        </div>
                        <div class="col-md-2">
                            <div class="small text-muted">الصلاحية</div>
                            ${expiryBadge}
                            <div class="small">${expiryDate}</div>
                        </div>
                        <div class="col-md-3">
                            <div class="btn-group w-100">
                                <a href="/hosting/${server.id}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-info-circle me-1"></i> تفاصيل
                                </a>
                                <a href="/console/${server.id}" class="btn btn-sm btn-outline">
                                    <i class="fas fa-terminal me-1"></i> الكونسول
                                </a>
                                <a href="/files/${server.id}" class="btn btn-sm btn-outline">
                                    <i class="fas fa-folder me-1"></i> الملفات
                                </a>
                            </div>
                            <div class="btn-group w-100 mt-2">
                                <button class="btn btn-sm btn-success" onclick="extendMinecraftServer('${server.id}')">
                                    <i class="fas fa-calendar-plus me-1"></i> تمديد
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="deleteMinecraftServer('${server.id}', '${server.name || 'غير محدد'}')">
                                    <i class="fas fa-trash me-1"></i> حذف
                                </button>
                            </div>
                        </div>
                    </div>
                    ${server.specs ? `
                        <div class="row mt-2">
                            <div class="col-md-12">
                                <div class="d-flex gap-3 small">
                                    <span><i class="fas fa-memory me-1"></i> RAM: ${server.specs.ram || 0} MB</span>
                                    <span><i class="fas fa-microchip me-1"></i> CPU: ${server.specs.cpu || 0} Core</span>
                                    <span><i class="fas fa-hdd me-1"></i> Storage: ${server.specs.storage || 0} GB</span>
                                </div>
                            </div>
                        </div>
                    ` : ''}
                </div>
            </div>
        `;
            }).join('');
        }

        function refreshMinecraftServers() {
            loadMinecraftServers();
            showToast('تم تحديث القائمة', 'success');
        }

        function extendMinecraftServer(id) {
            const days = prompt('كم يوم تريد إضافة؟', '30');
            if (!days || isNaN(days) || parseInt(days) <= 0) {
                showToast('يرجى إدخال عدد أيام صحيح', 'error');
                return;
            }

            fetch('/api/admin/extend-minecraft-server', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, days: parseInt(days) })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showToast('تم تمديد الاشتراك بنجاح', 'success');
                        loadMinecraftServers();
                    } else {
                        showToast('فشل التمديد: ' + (data.message || ''), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    showToast('خطأ في الاتصال', 'error');
                });
        }

        function deleteMinecraftServer(id, name) {
            if (!confirm(`هل أنت متأكد من حذف سيرفر Minecraft "${name}"؟\n\nتحذير: سيتم حذف جميع الملفات والبيانات المرتبطة بهذا السيرفر!`)) return;

            fetch('/api/admin/delete-minecraft-server', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        showToast('تم حذف السيرفر بنجاح', 'success');
                        loadMinecraftServers();
                    } else {
                        showToast('فشل الحذف: ' + (data.message || ''), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    showToast('خطأ في الاتصال', 'error');
                });
        }
    </script>