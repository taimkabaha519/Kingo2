<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#000000">
    <title>Hn Host - استضافة بوتات احترافية</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/png" href="/img/favicon.png">
</head>

<body>
    <div class="page-wrapper">
        <header class="site-header">
            <div class="container">
                <a href="/" class="brand" aria-label="الرئيسية">
                    <div class="brand-logo">H</div>
                    <span class="brand-name">Hn Host</span>
                </a>
                <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu">
                    <span class="visually-hidden">فتح/إغلاق القائمة</span>
                    <i class="fa-solid fa-bars"></i>
                </button>
                <nav class="main-nav" aria-label="التنقل الرئيسي">
                    <ul id="navMenu">
                        <li><a href="/" class="<%= active === 'dashboard' ? 'active' : '' %>"><i
                                    class="fas fa-home me-2"></i>الرئيسية</a></li>
                        <% if (user) { %>
                            <li><a href="/hostings" class="<%= active === 'hostings' ? 'active' : '' %>"><i
                                        class="fas fa-server me-2"></i>استضافاتي</a></li>
                            <% if (typeof hosting !=='undefined' && hosting && hosting.id) { %>
                                <li><a href="/hosting/<%= hosting.id %>#startup"
                                        class="<%= active === 'startup' ? 'active' : '' %>"><i
                                            class="fas fa-rocket me-2"></i>Startup</a></li>
                                <% } %>
                                    <li><a href="/console" class="<%= active === 'console' ? 'active' : '' %>"><i
                                                class="fas fa-terminal me-2"></i>الكونسول</a></li>
                                    <li><a href="/files" class="<%= active === 'files' ? 'active' : '' %>"><i
                                                class="fas fa-folder-open me-2"></i>الملفات</a></li>
                                    <% } %>
                                        <li><a href="/support" class="<%= active === 'support' ? 'active' : '' %>"><i
                                                    class="fas fa-headset me-2"></i>الدعم</a></li>
                    </ul>
                </nav>
                <div class="header-actions">
                    <% if (user) { %>
                        <% if (typeof notifications !=='undefined' ) { %>
                            <%- include('partials/notifications') %>
                                <% } %>
                                    <div class="user-menu">
                                        <img src="<%= user.avatar %>" alt="<%= user.username %>" class="user-avatar">
                                        <span class="user-name">
                                            <%= user.username %>
                                        </span>
                                        <% if (typeof isAdmin !=='undefined' && isAdmin) { %>
                                            <a href="/admin" class="btn btn-sm btn-primary me-1">
                                                <i class="fas fa-shield-alt"></i>
                                                <span class="d-none d-md-inline">الإدارة</span>
                                            </a>
                                            <% } %>
                                                <a href="/logout" class="btn btn-sm btn-outline">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <span class="d-none d-md-inline">خروج</span>
                                                </a>
                                    </div>
                                    <% } else { %>
                                        <a href="/auth/discord" class="btn btn-primary">
                                            <i class="fab fa-discord"></i>
                                            <span>تسجيل الدخول</span>
                                        </a>
                                        <% } %>
                </div>
            </div>
            <div class="nav-overlay" id="navOverlay" aria-hidden="true"></div>
        </header>

        <main id="app-content">
            <div class="container py-4">
                <%- body %>
            </div>
        </main>

    </div>

    <script src="https://cdn.socket.io/4.6.0/socket.io.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <%- script %>
</body>

</html>