<section class="section fade-in">
  <header class="section-head">
    <h2>شراء استضافة</h2>
    <p class="lead">اختر الباقة المناسبة لك واشترِ استضافة جديدة</p>
  </header>

  <% if (!user) { %>
    <div class="card p-4 text-center">
      <h3>يجب تسجيل الدخول أولاً</h3>
      <p class="text-muted mb-4">سجّل الدخول لحسابك لمتابعة عملية الشراء</p>
      <a href="/auth/discord" class="btn btn-primary">
        <i class="fab fa-discord me-2"></i> تسجيل الدخول
      </a>
    </div>
  <% } else { %>
    <div class="buy-hosting-container">
      <!-- Service Type Selection -->
      <div class="card mb-4">
        <div class="card-header">
          <h4><i class="fas fa-layer-group me-2"></i>نوع الخدمة</h4>
        </div>
        <div class="card-body">
          <div class="btn-group w-100" role="group">
            <input type="radio" class="btn-check" name="serviceType" id="discord" value="discord" checked>
            <label class="btn btn-outline-primary" for="discord">
              <i class="fab fa-discord me-2"></i> Discord Bot
            </label>
            
            <input type="radio" class="btn-check" name="serviceType" id="web" value="web">
            <label class="btn btn-outline-primary" for="web">
              <i class="fas fa-globe me-2"></i> Web Hosting
            </label>
            
            <input type="radio" class="btn-check" name="serviceType" id="minecraft" value="minecraft">
            <label class="btn btn-outline-primary" for="minecraft">
              <i class="fas fa-cube me-2"></i> Minecraft Server
            </label>
          </div>
        </div>
      </div>

      <!-- Packages Grid -->
      <div class="pricing-grid" id="packagesGrid">
        <% const packages = config?.prices?.discord || []; %>
        <% packages.forEach((pkg, index) => { %>
          <article class="card pricing-card <%= index === 1 ? 'plan-featured' : '' %>" data-service="discord">
            <div class="card-header">
              <h3><%= pkg.name %></h3>
            </div>
            <div class="price">$<%= pkg.price %><span class="per">/ <%= pkg.duration %> يوم</span></div>
            <ul class="features">
              <li><i class="fas fa-memory me-2"></i> RAM: <%= pkg.ram %> MB</li>
              <li><i class="fas fa-microchip me-2"></i> CPU: <%= pkg.cpu %> Core</li>
              <li><i class="fas fa-hdd me-2"></i> Storage: <%= pkg.storage %> GB</li>
              <li><i class="fas fa-calendar me-2"></i> المدة: <%= pkg.duration %> يوم</li>
            </ul>
            <div class="plan-cta">
              <button class="btn btn-primary w-100" onclick="selectPackage('discord', <%= index %>, <%= pkg.price %>)">
                <i class="fab fa-paypal me-2"></i> شراء بـ PayPal
              </button>
            </div>
          </article>
        <% }) %>
      </div>

      <!-- Hosting Name Input Modal -->
      <div class="modal-overlay" id="nameModal" style="display: none;">
        <div class="modal">
          <div class="modal-header">
            <h3>أدخل اسم الاستضافة</h3>
            <button class="btn-close" onclick="closeNameModal()">&times;</button>
          </div>
          <div class="modal-body">
            <input type="text" id="hostingName" class="form-control" placeholder="اسم الاستضافة" maxlength="50">
            <input type="hidden" id="selectedServiceType">
            <input type="hidden" id="selectedPackageIndex">
            <input type="hidden" id="selectedPrice">
            <div class="mt-3">
              <button class="btn btn-primary w-100" onclick="proceedToPayPal()">
                <i class="fab fa-paypal me-2"></i> متابعة الدفع
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</section>

<script src="https://www.paypal.com/sdk/js?client-id=<%= config?.payment?.paypal?.clientId || 'YOUR_CLIENT_ID' %>&currency=USD"></script>
<script>
  let selectedPackage = null;

  // Update packages when service type changes
  document.querySelectorAll('input[name="serviceType"]').forEach(radio => {
    radio.addEventListener('change', function() {
      const serviceType = this.value;
      updatePackages(serviceType);
    });
  });

  function updatePackages(serviceType) {
    const packages = <%- JSON.stringify(config?.prices || {}) %>;
    const servicePackages = packages[serviceType] || packages.default || [];
    const grid = document.getElementById('packagesGrid');
    
    grid.innerHTML = servicePackages.map((pkg, index) => `
      <article class="card pricing-card ${index === 1 ? 'plan-featured' : ''}" data-service="${serviceType}">
        <div class="card-header">
          <h3>${pkg.name}</h3>
        </div>
        <div class="price">$${pkg.price}<span class="per">/ ${pkg.duration} يوم</span></div>
        <ul class="features">
          <li><i class="fas fa-memory me-2"></i> RAM: ${pkg.ram} MB</li>
          <li><i class="fas fa-microchip me-2"></i> CPU: ${pkg.cpu} Core</li>
          <li><i class="fas fa-hdd me-2"></i> Storage: ${pkg.storage} GB</li>
          <li><i class="fas fa-calendar me-2"></i> المدة: ${pkg.duration} يوم</li>
        </ul>
        <div class="plan-cta">
          <button class="btn btn-primary w-100" onclick="selectPackage('${serviceType}', ${index}, ${pkg.price})">
            <i class="fab fa-paypal me-2"></i> شراء بـ PayPal
          </button>
        </div>
      </article>
    `).join('');
  }

  function selectPackage(serviceType, packageIndex, price) {
    document.getElementById('selectedServiceType').value = serviceType;
    document.getElementById('selectedPackageIndex').value = packageIndex;
    document.getElementById('selectedPrice').value = price;
    document.getElementById('nameModal').style.display = 'flex';
  }

  function closeNameModal() {
    document.getElementById('nameModal').style.display = 'none';
    document.getElementById('hostingName').value = '';
  }

  async function proceedToPayPal() {
    const hostingName = document.getElementById('hostingName').value.trim();
    const serviceType = document.getElementById('selectedServiceType').value;
    const packageIndex = parseInt(document.getElementById('selectedPackageIndex').value);
    const price = parseFloat(document.getElementById('selectedPrice').value);

    if (!hostingName) {
      alert('يرجى إدخال اسم الاستضافة');
      return;
    }

    try {
      // Create PayPal order
      const response = await fetch('/api/payment/create-order', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          serviceType,
          packageIndex,
          hostingName,
          amount: price
        })
      });

      const data = await response.json();
      
      if (data.success && data.orderId) {
        // Initialize PayPal buttons
        paypal.Buttons({
          createOrder: function(data, actions) {
            return actions.order.create({
              purchase_units: [{
                amount: {
                  value: price.toString()
                },
                description: `استضافة ${hostingName} - ${serviceType}`
              }]
            });
          },
          onApprove: async function(data, actions) {
            try {
              const order = await actions.order.capture();
              
              // Verify payment and create hosting
              const verifyResponse = await fetch('/api/payment/verify-payment', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                  orderId: order.id,
                  hostingName,
                  serviceType,
                  packageIndex
                })
              });

              const verifyData = await verifyResponse.json();
              
              if (verifyData.success) {
                alert('تم شراء الاستضافة بنجاح!');
                window.location.href = '/hostings';
              } else {
                alert('حدث خطأ: ' + (verifyData.message || 'فشل في إنشاء الاستضافة'));
              }
            } catch (error) {
              console.error('Payment error:', error);
              alert('حدث خطأ أثناء معالجة الدفع');
            }
          },
          onError: function(err) {
            console.error('PayPal error:', err);
            alert('حدث خطأ أثناء الدفع');
          }
        }).render('#paypal-button-container');
        
        closeNameModal();
        // Show PayPal button container (you'll need to add this to the modal)
      } else {
        alert('حدث خطأ: ' + (data.message || 'فشل في إنشاء طلب الدفع'));
      }
    } catch (error) {
      console.error('Error:', error);
      alert('حدث خطأ أثناء إنشاء طلب الدفع');
    }
  }
</script>

