<div class="fade-in">
    <h3 class="mb-3"><i class="fas fa-terminal me-2"></i> اختر الاستضافة لفتح Console</h3>
    <% if (!hostings || hostings.length === 0) { %>
        <div class="glass p-4">لا توجد استضافات متاحة</div>
    <% } else { %>
        <div class="row g-3">
            <% hostings.forEach(h => { %>
                <div class="col-md-4">
                    <a class="card glass hosting-card d-block text-decoration-none" href="/console/<%= h.id %>">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <div class="h5 mb-1"><i class="fas fa-robot me-2 text-primary"></i><%= h.name %></div>
                                <div class="small text-muted">انقر لفتح Console</div>
                            </div>
                            <span class="status-dot <%= h.status==='running'?'status-running':'status-stopped' %>"></span>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

